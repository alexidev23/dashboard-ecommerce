### Variables
@baseUrl = http://localhost:8000
@accessToken = 
@refreshToken = 

### Login - obtener access y refresh token
POST {{baseUrl}}/api/token/
Content-Type: application/json

{
  "username": "alexis",
  "password": "password"
}

### Refrescar el access token
POST {{baseUrl}}/api/token/refresh/
Content-Type: application/json

{
  "refresh": "{{refreshToken}}"
}

### Ver datos del usuario autenticado (/api/me/)
GET {{baseUrl}}/api/me/
Authorization: Bearer {{accessToken}}

### Listar usuarios (requiere rol superuser)
GET {{baseUrl}}/api/users/
Authorization: Bearer {{accessToken}}

### Crear usuario (requiere rol superuser)
POST {{baseUrl}}/api/users/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "username": "empleado2",
  "password": "password123",
  "email": "nuevo@example.com",
  "role": "stock"
}

### Ver detalle de un usuario (requiere rol superuser)
GET {{baseUrl}}/api/users/1/
Authorization: Bearer {{accessToken}}

### Editar un usuario (requiere rol superuser)
PATCH {{baseUrl}}/api/users/1/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "role": "hr"
}

### Borrar un usuario (requiere rol superuser)
DELETE {{baseUrl}}/api/users/1/
Authorization: Bearer {{accessToken}}

### Admin (panel completo de Django)
GET {{baseUrl}}/admin/

### Listar categorías
GET {{baseUrl}}/api/inventory/categories/
Authorization: Bearer {{accessToken}}

### Crear categoría
POST {{baseUrl}}/api/inventory/categories/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Calzado",
  "description": "Zapatos, zapatillas y botas"
}

### Listar productos
GET {{baseUrl}}/api/inventory/products/
Authorization: Bearer {{accessToken}}

### Buscar productos por nombre
GET {{baseUrl}}/api/inventory/products/?search=zapatilla urbana rojas
Authorization: Bearer {{accessToken}}

### Filtrar por categoría
GET {{baseUrl}}/api/inventory/products/?category=1
Authorization: Bearer {{accessToken}}

### Ordenar por precio
GET {{baseUrl}}/api/inventory/products/?ordering=price
Authorization: Bearer {{accessToken}}

### Productos con stock bajo
GET {{baseUrl}}/api/inventory/products/low_stock/
Authorization: Bearer {{accessToken}}

### Crear producto
POST {{baseUrl}}/api/inventory/products/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Zapatilla urbana rojas",
  "description": "Zapatilla urbana talle 22",
  "price": "12500.00",
  "stock": 20,
  "low_stock_threshold": 5,
  "category": 1,
  "is_active": true
}

### Ver detalle de un producto
GET {{baseUrl}}/api/inventory/products/1/
Authorization: Bearer {{accessToken}}

### Editar producto (parcial)
PATCH {{baseUrl}}/api/inventory/products/1/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "stock": 40
}

### Borrar producto (soft delete via is_active)
PATCH {{baseUrl}}/api/inventory/products/1/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "is_active": false
}

### Métricas del dashboard
GET {{baseUrl}}/api/metrics/
Authorization: Bearer {{accessToken}}

### Crear pedido con líneas
POST {{baseUrl}}/api/orders/orders/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "customer_name": "María García",
  "customer_email": "maria@example.com",
  "status": "pending",
  "notes": "Entregar por la tarde",
  "items": [
    { "product": 1, "quantity": 2, "unit_price": 322 },
    { "product": 2, "quantity": 1, "unit_price": 300 }
  ]
}

### Listar pedidos
GET {{baseUrl}}/api/orders/orders/
Authorization: Bearer {{accessToken}}

### Filtrar por estado
GET {{baseUrl}}/api/orders/orders/?status=pending
Authorization: Bearer {{accessToken}}